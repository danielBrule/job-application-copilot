# Copy this file to .env and adjust values for your local environment.
# Relative paths are resolved from the directory where the application is started.

JAC_DATA_DIR=data
JAC_ASSESSMENT_WORKER_COUNT=1
JAC_CV_WORKER_COUNT=1
JAC_DEFAULT_SOURCE=LinkedIn
JAC_DEFAULT_LOCATION=UK
JAC_DEFAULT_LANGUAGE=EN

# Optional advanced overrides:
# JAC_DATABASE_PATH=D:\Databases\job_application_copilot.db
# JAC_CV_FOLDER=D:\Documents\CVs
# JAC_LOGS_FOLDER=D:\ApplicationLogs
# JAC_REFERENCE_FOLDER=D:\PrivateCareerDocuments

# Keep the real key only in .env or the process environment.
OPENAI_API_KEY=
